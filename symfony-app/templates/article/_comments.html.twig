{# Threaded comments under an article (view page only — the publish-flow
   preview renders no comments). Anonymous visitors see the thread but no
   comment/reply forms. #}
<div id="comments" class="border-top mt-4 pt-3">
    <h4>Comments</h4>

    {% for node in comments %}
        {{ include('article/_comment.html.twig', {node: node}) }}
    {% else %}
        <div class="text-muted">No comments yet</div>
    {% endfor %}

    {% if isLoggedIn %}
        <form class="mt-3" method="post" action="{{ path('article_comment', {id: article.id}) }}">
            <div class="form-group">
                <label class="font-weight-bold" for="comment-text">Add a comment:</label>
                <textarea class="form-control" id="comment-text" name="text" rows="3"></textarea>
            </div>
            <div class="text-center">
                <button type="submit" class="btn btn-wmffl">Post Comment</button>
            </div>
        </form>

        <script>
            document.querySelectorAll('.reply-toggle').forEach(function (link) {
                link.addEventListener('click', function (event) {
                    event.preventDefault();
                    document.getElementById('reply-form-' + link.dataset.comment).classList.toggle('d-none');
                });
            });
        </script>
    {% endif %}
</div>
