{# One comment and, indented beneath it, its replies. Recursive. #}
<div class="border-top py-2" id="comment-{{ node.comment.id }}">
    <div class="font-weight-bold">{{ node.comment.author.name }}</div>
    <div class="small text-muted">{{ node.comment.dateCreated|date('m/d/y h:i a') }}</div>
    <div class="py-1">{{ node.comment.commentText|nl2br }}</div>

    {% if isLoggedIn %}
        <a href="#" class="small reply-toggle" data-comment="{{ node.comment.id }}">Reply</a>
        <form class="d-none mt-2" id="reply-form-{{ node.comment.id }}" method="post"
              action="{{ path('article_comment', {id: article.id}) }}">
            <input type="hidden" name="parent" value="{{ node.comment.id }}"/>
            <input type="hidden" name="_token" value="{{ csrf_token('comment') }}"/>
            <div class="form-group">
                <textarea class="form-control" name="text" rows="2"></textarea>
            </div>
            <div class="text-center">
                <button type="submit" class="btn btn-wmffl">Post Reply</button>
            </div>
        </form>
    {% endif %}

    {% if node.children %}
        <div class="ml-4">
            {% for child in node.children %}
                {{ include('article/_comment.html.twig', {node: child}) }}
            {% endfor %}
        </div>
    {% endif %}
</div>
