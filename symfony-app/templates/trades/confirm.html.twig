{% extends 'base.html.twig' %}

{% block title %}Confirm Trade Offer{% endblock %}

{% block content %}
<h1 class="text-center">Confirm Offer</h1>
<hr size="1"/>

{% include 'transactions/_transmenu.html.twig' %}

<div class="container">
    <p>Review the current terms of the offer. If the offer is still not what you
        intended you may select "Edit Offer" and return to editing the offer or
        "Cancel" to discard these changes. If the trade conditions meet your
        satisfaction you may type some comments to the other owner and select
        "Make Offer". The offer will then be recorded and an email notifying the
        other owner will be sent. This offer will become official when accepted
        by the other team. Before that time, either you or the other team may
        amend or reject the trade. If no action is taken for seven days the
        offer will automatically become void.</p>

    <h3 class="text-center">Current Offer</h3>

    <p class="text-center">{{ sentence }}</p>

    <form action="{{ path('trades_offer_confirm') }}" method="POST">
        {% include 'trades/_selection_fields.html.twig' %}
        <div class="form-group">
            <label for="comments">Comments:</label>
            <textarea class="form-control" name="comments" id="comments" cols="60" rows="8"></textarea>
        </div>
        <div class="text-center">
            <button type="submit" name="offer" value="1" class="btn btn-wmffl m-1">Make Offer</button>
            <button type="submit" name="cancel" value="1" class="btn btn-wmffl m-1">Cancel</button>
        </div>
    </form>

    <form action="{{ path('trades_offer') }}" method="POST">
        {% include 'trades/_selection_fields.html.twig' %}
        <div class="text-center">
            <button type="submit" name="edit" value="1" class="btn btn-wmffl m-1">Edit Offer</button>
        </div>
    </form>
</div>
{% endblock %}
