{# Other links, admin-managed via /admin/quicklinks. The including page
   skips its card wrapper when the list is empty, so this partial only
   renders when there is at least one visible link. #}
<div class="cat">Other Links</div>

<ul class="list-group">
    {% for link in quicklinks %}
    <li class="list-group-item float-left col-lg-4 col-md-6 col-12"><a href="{{ link.url }}">{{ link.label }}</a></li>
    {% endfor %}
</ul>
