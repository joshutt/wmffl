{% extends 'base.html.twig' %}

{% block title %}Waiver Order{% endblock %}

{% block content %}
<h1 class="text-center">Waiver Wire</h1>
<hr/>

{% include 'transactions/_transmenu.html.twig' %}

<div class="container">
    <div class="row">
        <div class="col-12 col-md-6">
            The waiver selection order for {{ weekName }}.
            <ol>
                {% for team in order %}
                    <li>{{ team }}</li>
                {% endfor %}
            </ol>
        </div>
        {% if memberPicks is not null %}
            <div class="col-12 col-md-6">
                Your current waiver priority for this week:
                <ol>
                    {% for pick in memberPicks %}
                        <li>{{ pick.firstname }} {{ pick.lastname }} ({{ pick.pos }}-{{ pick.team }})</li>
                    {% endfor %}
                </ol>
            </div>
        {% endif %}
    </div>
    <hr/>

    <p>Last Week's waiver pickups</p>

    {% if awards is empty %}
        No Waiver pickups last week
    {% else %}
        <table class="w-100">
            {% for award in awards %}
                <tr>
                    <td>{{ award.pick }}.</td>
                    <td>{{ award.name }}</td>
                    <td>{{ award.firstname }} {{ award.lastname }} ({{ award.pos }}-{{ award.team }})</td>
                </tr>
            {% endfor %}
        </table>
    {% endif %}
</div>
{% endblock %}
