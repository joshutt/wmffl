{% extends 'admin/base.html.twig' %}

{% block title %}Admin - Teams{% endblock %}

{% block admin_content %}
<h2 class="mt-2">Teams</h2>

<table class="table table-sm table-striped table-bordered">
    <thead>
        <tr>
            <th>Name</th>
            <th>Abbrev</th>
            <th>Division</th>
            <th>Active</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for team in teams %}
        <tr>
            <td>{{ team.name }}</td>
            <td>{{ team.abbreviation }}</td>
            <td>{{ divisionNames[team.division] ?? team.division }}</td>
            <td>{{ team.active ? 'Yes' : 'No' }}</td>
            <td class="text-center">
                <a class="btn btn-sm btn-wmffl" href="{{ path('admin_teams_edit', {id: team.id}) }}">Edit</a>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
