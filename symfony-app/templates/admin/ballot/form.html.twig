{% extends 'admin/base.html.twig' %}

{% block title %}Admin - {{ issue ? 'Edit Issue' : 'New Issue' }}{% endblock %}

{% block admin_content %}
<h2 class="mt-2">{{ issue ? 'Edit Issue' : 'New Issue' }}</h2>

<form method="post" action="{{ issue ? path('admin_ballot_update', {id: issue.id}) : path('admin_ballot_create') }}" style="max-width: 600px;">

    <div class="mb-3">
        <label class="form-label">Issue Number <span class="text-danger">*</span></label>
        <input type="text" name="issueNum" class="form-control" maxlength="10"
               value="{{ issue ? issue.issueNum : '' }}" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Issue Name <span class="text-danger">*</span></label>
        <input type="text" name="issueName" class="form-control" maxlength="40"
               value="{{ issue ? issue.issueName : '' }}" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Season <span class="text-danger">*</span></label>
        <input type="number" name="season" class="form-control" min="2000" max="2099"
               value="{{ currentSeason }}" required>
    </div>

    <div class="mb-3">
        <label class="form-label">Sponsor</label>
        <select name="sponsor" class="form-select">
            <option value="">— None —</option>
            {% for team in teams %}
            <option value="{{ team.id }}"
                {% if issue and issue.sponsor and issue.sponsor.id == team.id %}selected{% endif %}>
                {{ team.name }}
            </option>
            {% endfor %}
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea name="description" class="form-control" rows="4">{{ issue ? issue.description : '' }}</textarea>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">Start Date</label>
            <input type="date" name="startDate" class="form-control"
                   value="{{ issue and issue.startDate ? issue.startDate|date('Y-m-d') : '' }}">
            <div class="form-text">Leave blank to set later.</div>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label">Deadline</label>
            <input type="date" name="deadline" class="form-control"
                   value="{{ issue and issue.deadline ? issue.deadline|date('Y-m-d') : '' }}">
            <div class="form-text">Leave blank to set later.</div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Result</label>
        <select name="result" class="form-select">
            <option value="">— Pending —</option>
            <option value="Accept" {% if issue and issue.result == 'Accept' %}selected{% endif %}>Accept</option>
            <option value="Reject" {% if issue and issue.result == 'Reject' %}selected{% endif %}>Reject</option>
            <option value="Tie"    {% if issue and issue.result == 'Tie'    %}selected{% endif %}>Tie</option>
        </select>
    </div>

    <div class="d-flex gap-2">
        <div class="text-center">
            <button type="submit" class="btn btn-wmffl">{{ issue ? 'Save Changes' : 'Create Issue' }}</button>
        </div>
        <a href="{{ path('admin_ballot') }}" class="btn btn-outline-secondary">Cancel</a>
    </div>

</form>
{% endblock %}
