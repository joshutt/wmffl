{% extends 'admin/base.html.twig' %}

{% block title %}Admin - Season Rules{% endblock %}

{% block admin_content %}
<h2 class="mt-2">Season Rules</h2>
<p class="text-muted">
    Each season's league rules: schedule structure, finances, scoring and
    protections. Historical seasons were seeded with the current rules -
    correct them as the real rules are recreated, then mark the season
    verified.
</p>

{% if latest %}
<form method="post" action="{{ path('admin_seasons_clone') }}" class="text-center my-2">
    <input type="hidden" name="_token" value="{{ csrf_token('admin_seasons') }}"/>
    <button type="submit" class="btn btn-wmffl">
        Create {{ latest.season + 1 }} (copy of {{ latest.season }})
    </button>
</form>
{% endif %}

<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>Season</th>
            <th class="text-right">Entry Fee</th>
            <th class="text-right">Reg. Weeks</th>
            <th>Strategy</th>
            <th>Verified</th>
            <th>Notes</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        {% for season in seasons %}
        <tr>
            <td>{{ season.season }}</td>
            <td class="text-right">${{ season.entryFee|number_format(2) }}</td>
            <td class="text-right">{{ season.regularSeasonWeeks }}</td>
            <td>{{ season.scoringStrategy }}</td>
            <td>
                {% if season.verified %}
                <span class="badge badge-success">verified</span>
                {% else %}
                <span class="badge badge-warning">unconfirmed</span>
                {% endif %}
            </td>
            <td>{{ season.notes ? (season.notes|length > 60 ? season.notes|slice(0, 60) ~ '...' : season.notes) : '' }}</td>
            <td class="text-center">
                <a class="btn btn-sm btn-wmffl" href="{{ path('admin_seasons_edit', {season: season.season}) }}">Edit</a>
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
