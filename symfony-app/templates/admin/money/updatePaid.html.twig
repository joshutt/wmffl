{% extends 'admin/base.html.twig' %}

{% block title %}{{ season }} Paid Status - Admin{% endblock %}

{% block javascripts %}
<script src="/base/js/admin/money.js"></script>
{% endblock %}

{% block admin_content %}
<div class="card px-0 m-2">
    <div class="card-header font-weight-bold text-center">{{ season }} Paid Status</div>
    <div class="card-body p-0">
        <table class="table table-striped table-hover table-sm text-center mb-0" id="paidTable">
            <thead>
            <tr>
                <th scope="col">Team</th>
                <th scope="col">Previous</th>
                <th scope="col">Entry Fee</th>
                <th scope="col">Late Fee</th>
                <th scope="col">Amt Paid</th>
                <th scope="col">Paid?</th>
            </tr>
            </thead>
            <tbody>
            {% for p in paid %}
            <tr>
                <td>{{ p.team.name }}</td>
                <td>${{ p.previous|number_format(2, '.', ',') }}</td>
                <td>${{ p.entryFee|number_format(2, '.', ',') }}</td>
                <td><span id="late-{{ p.id }}" class="editable-span">${{ p.lateFee|number_format(2, '.', ',') }}</span></td>
                <td><span id="amt-{{ p.id }}" class="editable-span">${{ p.amtPaid|number_format(2, '.', ',') }}</span></td>
                <td>
                    <label class="switch">
                        <input type="checkbox" onchange="toggleChange(event);" id="paid-{{ p.id }}"
                               value="" {{ p.paid ? 'checked="true"' : '' }} />
                        <span class="slider round"></span>
                    </label>
                </td>
            </tr>
            {% endfor %}
            <tr>
                <td colspan="6">
                    <button name="update" class="btn btn-wmffl" onclick="location.reload();">Refresh</button>
                </td>
            </tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer">
        <a href="{{ path('admin_money_paid', {season: season - 1}) }}">&#8592; {{ season - 1 }}</a>
        {% if season < currentSeason %}
            &nbsp;|&nbsp;
            <a href="{{ path('admin_money_paid', {season: season + 1}) }}">{{ season + 1 }} &#8594;</a>
        {% endif %}
    </div>
</div>
{% endblock %}
