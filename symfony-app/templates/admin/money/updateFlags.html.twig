{% extends 'admin/base.html.twig' %}

{% block title %}{{ season }} Season Flags - Admin{% endblock %}

{% block admin_content %}
<div class="card px-0 m-2">
    <div class="card-header font-weight-bold text-center">{{ season }} Season Flags</div>
    <div class="card-body p-0">
        <form action="{{ path('admin_money_process_flags') }}" method="post">
            <input type="hidden" name="season" value="{{ season }}"/>
            <table class="table table-striped table-hover table-sm text-center mb-0">
                <thead>
                <tr>
                    <th scope="col">Team</th>
                    <th scope="col">Flags</th>
                    <th scope="col">Division</th>
                    <th scope="col">Playoffs</th>
                    <th scope="col">Finalist</th>
                    <th scope="col">Champion</th>
                </tr>
                </thead>
                <tbody>
                {% for f in flags %}
                <tr>
                    <td>{{ f.team.name }}</td>
                    <td><input type="text" name="flag-{{ f.id }}" value="{{ f.flags }}" size="3"/></td>
                    <td><input type="checkbox" name="div-{{ f.id }}" {{ f.divisionWinner ? 'checked' : '' }} /></td>
                    <td><input type="checkbox" name="po-{{ f.id }}" {{ f.playoffTeam ? 'checked' : '' }} /></td>
                    <td><input type="checkbox" name="fin-{{ f.id }}" {{ f.finalist ? 'checked' : '' }} /></td>
                    <td><input type="checkbox" name="cham-{{ f.id }}" {{ f.champion ? 'checked' : '' }} /></td>
                </tr>
                {% endfor %}
                <tr>
                    <th colspan="6"><input type="submit" class="btn btn-wmffl" value="Save"/></th>
                </tr>
                </tbody>
            </table>
        </form>
    </div>
    <div class="card-footer">
        <a href="{{ path('admin_money_flags', {season: season - 1}) }}">&#8592; {{ season - 1 }}</a>
        {% if season < currentSeason %}
            &nbsp;|&nbsp;
            <a href="{{ path('admin_money_flags', {season: season + 1}) }}">{{ season + 1 }} &#8594;</a>
        {% endif %}
    </div>
</div>
{% endblock %}
